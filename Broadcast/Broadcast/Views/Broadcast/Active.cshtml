@model IEnumerable<Broadcast.Models.BroadcastMessage>

@{
    ViewData["Title"] = "Active Messages";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-5">
                <i class="bi bi-broadcast-pin"></i> Active Broadcast Messages
            </h1>
            <p class="text-muted">Currently active messages visible to all users</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <a asp-action="Index" class="btn btn-outline-primary">All Messages</a>
                <a asp-action="Active" class="btn btn-outline-primary active">Active Messages</a>
            </div>
        </div>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="row">
            @foreach (var message in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm @(message.Priority == Broadcast.Models.MessagePriority.Urgent ? "border-danger" : "")">
                        <div class="card-header @(message.Priority == Broadcast.Models.MessagePriority.Urgent ? "bg-danger text-white" : "bg-light")">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">@message.Title</h5>
                                @switch (message.Priority)
                                {
                                    case Broadcast.Models.MessagePriority.Urgent:
                                        <span class="badge bg-light text-danger">Urgent</span>
                                        break;
                                    case Broadcast.Models.MessagePriority.High:
                                        <span class="badge bg-warning">High</span>
                                        break;
                                    case Broadcast.Models.MessagePriority.Normal:
                                        <span class="badge bg-info">Normal</span>
                                        break;
                                    case Broadcast.Models.MessagePriority.Low:
                                        <span class="badge bg-secondary">Low</span>
                                        break;
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@message.Content</p>
                            @if (!string.IsNullOrEmpty(message.Category))
                            {
                                <span class="badge bg-primary">@message.Category</span>
                            }
                        </div>
                        <div class="card-footer text-muted">
                            <small>
                                <i class="bi bi-clock"></i> @message.CreatedAt.ToString("MMM dd, yyyy")
                                <span class="float-end">
                                    <i class="bi bi-eye"></i> @message.ViewCount views
                                </span>
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle display-4"></i>
            <h3 class="mt-3">No Active Messages</h3>
            <p>There are currently no active broadcast messages.</p>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}