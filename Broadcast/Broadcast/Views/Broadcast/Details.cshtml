@model Broadcast.Models.BroadcastMessage

@{
    ViewData["Title"] = "Message Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="mb-0">
                            <i class="bi bi-envelope-open"></i> Message Details
                        </h2>
                        <div>
                            @switch (Model.Status)
                            {
                                case Broadcast.Models.MessageStatus.Sent:
                                    <span class="badge bg-success fs-6">Sent</span>
                                    break;
                                case Broadcast.Models.MessageStatus.Scheduled:
                                    <span class="badge bg-primary fs-6">Scheduled</span>
                                    break;
                                case Broadcast.Models.MessageStatus.Draft:
                                    <span class="badge bg-secondary fs-6">Draft</span>
                                    break;
                                case Broadcast.Models.MessageStatus.Archived:
                                    <span class="badge bg-dark fs-6">Archived</span>
                                    break;
                            }
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <h3 class="display-6">@Model.Title</h3>
                            <hr />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="alert alert-light border">
                                <p class="lead">@Model.Content</p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <dl class="row">
                                <dt class="col-sm-4">Priority:</dt>
                                <dd class="col-sm-8">
                                    @switch (Model.Priority)
                                    {
                                        case Broadcast.Models.MessagePriority.Urgent:
                                            <span class="badge bg-danger">Urgent</span>
                                            break;
                                        case Broadcast.Models.MessagePriority.High:
                                            <span class="badge bg-warning text-dark">High</span>
                                            break;
                                        case Broadcast.Models.MessagePriority.Normal:
                                            <span class="badge bg-info">Normal</span>
                                            break;
                                        case Broadcast.Models.MessagePriority.Low:
                                            <span class="badge bg-secondary">Low</span>
                                            break;
                                    }
                                </dd>

                                <dt class="col-sm-4">Category:</dt>
                                <dd class="col-sm-8">@(Model.Category ?? "N/A")</dd>

                                <dt class="col-sm-4">Created By:</dt>
                                <dd class="col-sm-8">@Model.CreatedBy</dd>
                            </dl>
                        </div>

                        <div class="col-md-6 mb-3">
                            <dl class="row">
                                <dt class="col-sm-4">Created:</dt>
                                <dd class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</dd>

                                @if (Model.ScheduledFor.HasValue)
                                {
                                    <dt class="col-sm-4">Scheduled For:</dt>
                                    <dd class="col-sm-8">@Model.ScheduledFor.Value.ToString("MMMM dd, yyyy hh:mm tt")</dd>
                                }

                                @if (Model.SentAt.HasValue)
                                {
                                    <dt class="col-sm-4">Sent At:</dt>
                                    <dd class="col-sm-8">@Model.SentAt.Value.ToString("MMMM dd, yyyy hh:mm tt")</dd>
                                }

                                <dt class="col-sm-4">View Count:</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-primary">@Model.ViewCount views</span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            @if (Model.Status != Broadcast.Models.MessageStatus.Sent)
                            {
                                <form asp-action="Send" asp-route-id="@Model.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success" onclick="return confirm('Send this message now?')">
                                        <i class="bi bi-send"></i> Send Now
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}