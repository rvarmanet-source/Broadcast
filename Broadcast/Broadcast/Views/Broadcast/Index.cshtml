@model IEnumerable<Broadcast.Models.BroadcastMessage>

@{
    ViewData["Title"] = "Broadcast Messages";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">
                <i class="bi bi-broadcast"></i> Broadcast Messages
            </h1>
            <p class="text-muted">Manage and send broadcast messages to all users</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle"></i> Create New Message
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <a asp-action="Index" class="btn btn-outline-primary active">All Messages</a>
                <a asp-action="Active" class="btn btn-outline-primary">Active Messages</a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Category</th>
                                <th>Created</th>
                                <th>Views</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.Title</strong>
                                        <br />
                                        <small class="text-muted">@item.Content.Substring(0, Math.Min(50, item.Content.Length))...</small>
                                    </td>
                                    <td>
                                        @switch (item.Priority)
                                        {
                                            case Broadcast.Models.MessagePriority.Urgent:
                                                <span class="badge bg-danger">Urgent</span>
                                                break;
                                            case Broadcast.Models.MessagePriority.High:
                                                <span class="badge bg-warning">High</span>
                                                break;
                                            case Broadcast.Models.MessagePriority.Normal:
                                                <span class="badge bg-info">Normal</span>
                                                break;
                                            case Broadcast.Models.MessagePriority.Low:
                                                <span class="badge bg-secondary">Low</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (item.Status)
                                        {
                                            case Broadcast.Models.MessageStatus.Sent:
                                                <span class="badge bg-success">Sent</span>
                                                break;
                                            case Broadcast.Models.MessageStatus.Scheduled:
                                                <span class="badge bg-primary">Scheduled</span>
                                                break;
                                            case Broadcast.Models.MessageStatus.Draft:
                                                <span class="badge bg-secondary">Draft</span>
                                                break;
                                            case Broadcast.Models.MessageStatus.Archived:
                                                <span class="badge bg-dark">Archived</span>
                                                break;
                                        }
                                    </td>
                                    <td>@(item.Category ?? "-")</td>
                                    <td>
                                        <small>@item.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    </td>
                                    <td>@item.ViewCount</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (item.Status != Broadcast.Models.MessageStatus.Sent)
                                            {
                                                <form asp-action="Send" asp-route-id="@item.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-success" title="Send Now" onclick="return confirm('Send this message now?')">
                                                        <i class="bi bi-send"></i>
                                                    </button>
                                                </form>
                                            }
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger" title="Archive" onclick="return confirm('Archive this message?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <h3 class="mt-3">No Messages Found</h3>
                    <p class="text-muted">Create your first broadcast message to get started.</p>
                    <a asp-action="Create" class="btn btn-primary">Create Message</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}